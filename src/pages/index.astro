---
import BaseLayout from "../layouts/BaseLayout.astro";

const calendlyUrl =
  "https://calendly.com/henneberg-webdesign-info/tectum-ecobau-meeting";

const brandNote = "Deutsch‑serbische Kooperation · Vorfertigung in Holz · Auslieferung DACH";
---

<BaseLayout
  title="Tectum Ecobau — Tiny Haus & Modulbau aus Holz"
  description="Professionelle Homepage für Tectum Ecobau: Tiny Häuser & Holzmodule, klare Prozesse von Planung bis Montage, Lösungen für Ferienparks (Park Renewal), Kita‑Module und Wellness‑Boxen — inkl. Meeting via Calendly."
>
  <header class="topbar">
    <div class="container topbar-inner">
      <a class="brand" href="#top">
        <span class="mark" aria-hidden="true"></span>
        <div>
          <strong>Tectum Ecobau</strong>
          <div><span>{brandNote}</span></div>
        </div>
      </a>
      <nav class="nav" aria-label="Sektionen">
        <a href="#loesungen">Lösungen</a>
        <a href="#prozess">Ablauf</a>
        <a href="#referenzen">Referenzen</a>
        <a href="#faq">FAQ</a>
        <a class="btn primary" href="#kontakt">
          Projekt anfragen <span class="arrow" aria-hidden="true"></span>
        </a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="hero">
      <div class="container">
        <div class="kicker">
          <span class="dot" aria-hidden="true"></span>
          Moderne Tiny Häuser & Holzmodule — gebaut wie ein Produkt, geliefert wie ein Prozess
        </div>
        <h1>
          Premium‑Holzmodule,
          <span style="color:var(--accent)">schnell montiert</span> —
          <br />für Wohnen, Hospitality und soziale Infrastruktur.
        </h1>
        <p class="lead">
          Tectum Ecobau verbindet Holzbau‑Qualität mit industrieller Vorfertigung. Das Ergebnis:
          modulare Einheiten mit klar kalkulierbaren Zeitplänen — von der Konfiguration bis zur
          Montage vor Ort. Ideal für Tiny Houses, Park‑Renewal‑Lodges, Kita‑Module und Wellness‑Boxen.
        </p>

        <div class="hero-split">
          <div class="stage">
            <div class="stage-inner">
              <h3>Warum Tectum</h3>
              <p>
                Wir bauen nicht „irgendwie modular“. Wir bauen so, dass Betreiber, Kommunen und
                private Bauherren eine klare Entscheidung treffen können: definierte Varianten,
                transparente Abläufe, belastbare Unterlagen.
              </p>
              <div class="metrics" aria-label="Highlights">
                <div class="metric">
                  <div class="num">Vorfertigung</div>
                  <div class="lbl">schnelle Montage · wenig Downtime</div>
                </div>
                <div class="metric">
                  <div class="num">Holzbau</div>
                  <div class="lbl">Raumklima · Ästhetik · Nachhaltigkeit</div>
                </div>
                <div class="metric">
                  <div class="num">DACH‑Fokus</div>
                  <div class="lbl">Prozess + Unterlagen für Genehmigung & Betrieb</div>
                </div>
              </div>
              <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap">
                <a class="btn primary" href="#kontakt">
                  Projekt starten <span class="arrow" aria-hidden="true"></span>
                </a>
                <a class="btn ghost" href="#prozess">Ablauf ansehen</a>
              </div>
            </div>
            <div class="stage-visual" aria-hidden="true">
              <div class="gridlines"></div>
              <div class="visual-caption">
                <span class="chip"><span class="mini" aria-hidden="true"></span> <b>Design</b> · modern · warm</span>
                <span class="chip"><b>System</b> · Varianten · Qualität</span>
              </div>
            </div>
          </div>

          <aside class="stage">
            <div class="stage-inner">
              <h3>Schnelle Orientierung</h3>
              <p>
                Wähle den Einstieg, der zu deiner Entscheidung passt — wir führen dich über Nutzen,
                Prozess und nächste Schritte.
              </p>
              <div style="margin-top:12px; display:grid; gap:10px">
                <a class="btn" href="#loesungen">
                  Lösungen entdecken <span class="arrow" aria-hidden="true"></span>
                </a>
                <a class="btn" href="#referenzen">
                  Beispiele & Use‑Cases <span class="arrow" aria-hidden="true"></span>
                </a>
                <a class="btn" href="#kontakt">
                  Angebot / Audit anfragen <span class="arrow" aria-hidden="true"></span>
                </a>
              </div>
              <div style="margin-top:12px">
                <span class="chip"><b>Hinweis</b>: diese Seite ist ein Design‑/Struktur‑Entwurf.</span>
              </div>
            </div>
          </aside>
        </div>

        <div class="marquee" aria-hidden="true">
          <div class="marquee-track">
            <span>tiny houses</span><span>holzmodule</span><span>park renewal</span><span>kita‑module</span><span>wellness box</span>
            <span>serielle vorfertigung</span><span>prozess & montage</span><span>design & raumklima</span><span>tiny houses</span><span>holzmodule</span><span>park renewal</span><span>kita‑module</span><span>wellness box</span>
            <span>serielle vorfertigung</span><span>prozess & montage</span><span>design & raumklima</span>
          </div>
        </div>
      </div>
    </section>

    <section id="loesungen" class="section">
      <div class="container">
        <div class="section-head">
          <h2>Lösungen</h2>
          <p class="hint">
            Drei Produktwelten — jeweils mit eigener Story, aber gleicher Kern: Holzbauqualität,
            Vorfertigung und ein sauberer Ablauf.
          </p>
        </div>

        <div class="cards">
          <article class="card">
            <span class="tag c">Living</span>
            <h3>Tiny Houses & Modulwohnen</h3>
            <p>
              Für private Bauherren und Projektentwickler: modern, warm, langlebig — mit klarer
              Planung und schneller Montage.
            </p>
            <ul>
              <li>Schlüsselfertige Varianten & Ausstattungs‑Pakete</li>
              <li>Materialität, Raumklima und Designfokus</li>
              <li>Konfiguration → Produktion → Montage</li>
            </ul>
          </article>

          <article class="card">
            <span class="tag a">Hospitality</span>
            <h3>Park Renewal (Rolling Swap)</h3>
            <p>
              Für Ferienpark‑Betreiber & Investoren: Austausch veralteter Einheiten im laufenden Betrieb
              — minimaler Umsatzausfall, maximaler Uplift.
            </p>
            <ul>
              <li>„Rolling Swap“: morgens raus, morgen rein — Downtime nahe null</li>
              <li>Upgrade von ADR & Auslastung durch Premium‑Lodges</li>
              <li>ESG/GEG‑Druck als Marktkatalysator</li>
            </ul>
          </article>

          <article class="card">
            <span class="tag b">Public</span>
            <h3>Kita‑Module & Erweiterungen</h3>
            <p>
              Für Kommunen & Träger: Erweiterungs‑ und Naturkita‑Module mit Fokus auf Raumqualität,
              minimaler Betriebsstörung und planbarem Zeitplan.
            </p>
            <ul>
              <li>Kita‑Erweiterungsmodul (Inklusion/U3/Mehrzweck)</li>
              <li>Wald-/Naturkita‑Modul (winterfest, genehmigungsfähig)</li>
              <li>Förderlogik + Unterlagenpaket als Deal‑Beschleuniger</li>
            </ul>
          </article>
        </div>

        <div class="two-col">
          <div class="stage">
            <div class="stage-inner">
              <h3>Wellness Box (Premium‑Add‑On)</h3>
              <p>
                Für Hosts, Glamping & Private: modulare Spa‑Einheiten (Sauna/Kälte/Relax) als
                sichtbarer Mehrwert — perfekt für Nebensaison und „Unique stays“.
              </p>
              <div class="pill"><b>Nutzen</b> · höhere ADR · bessere Auslastung · klare Positionierung</div>
            </div>
          </div>
          <div class="stage">
            <div class="stage-inner">
              <h3>Unterlagen & Sicherheit</h3>
              <p>
                Für B2G/B2B zählt weniger „schön“, mehr „prüfbar“: Nachweise, Checklisten, Prozess.
                Wir liefern die Struktur, damit Entscheidungen schneller fallen.
              </p>
              <div class="pill"><b>Deliverables</b> · Unterlagen‑Mappe · Audit · klare Timeline</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="prozess" class="section">
      <div class="container">
        <div class="section-head">
          <h2>Ablauf</h2>
          <p class="hint">
            Ein Prozess, der sich wie ein Produkt anfühlt: klar, wiederholbar, schnell — und trotzdem
            flexibel genug für individuelle Projekte.
          </p>
        </div>

        <div class="timeline" role="list">
          <div class="step" role="listitem">
            <div class="idx">01</div>
            <div>
              <div class="ttl">Kurz‑Check & Zielbild</div>
              <div class="txt">
                Was wird gebaut — und für wen? Wir klären Standort, Nutzung, Budget‑Rahmen,
                Timeline und die passende Produktwelt.
              </div>
              <div class="meta">
                <span class="pill">15–30 min Call</span>
                <span class="pill">Use‑Case & Anforderungen</span>
              </div>
            </div>
          </div>
          <div class="step" role="listitem">
            <div class="idx">02</div>
            <div>
              <div class="ttl">Konfiguration & Angebot</div>
              <div class="txt">
                Varianten wählen (Grundriss, Ausstattung, Technik), Schnittstellen klären (Fundament,
                Anschlüsse), Kosten transparent machen.
              </div>
              <div class="meta">
                <span class="pill">Fixe Pakete</span>
                <span class="pill">Optionen & Upgrades</span>
              </div>
            </div>
          </div>
          <div class="step" role="listitem">
            <div class="idx">03</div>
            <div>
              <div class="ttl">Unterlagen & Genehmigung</div>
              <div class="txt">
                Für Projekte mit Behörden/Trägern: Nachweise, Checklisten, Prozess‑Roadmap.
                Ziel: Unsicherheit reduzieren — Entscheidungen beschleunigen.
              </div>
              <div class="meta">
                <span class="pill">Nachweis‑Mappe</span>
                <span class="pill">Timeline & Verantwortliche</span>
              </div>
            </div>
          </div>
          <div class="step" role="listitem">
            <div class="idx">04</div>
            <div>
              <div class="ttl">Produktion</div>
              <div class="txt">
                Industrielle Vorfertigung im Werk — Qualität, Wiederholbarkeit und Tempo.
              </div>
              <div class="meta">
                <span class="pill">Vorfertigung</span>
                <span class="pill">Qualitäts‑Check</span>
              </div>
            </div>
          </div>
          <div class="step" role="listitem">
            <div class="idx">05</div>
            <div>
              <div class="ttl">Logistik & Montage</div>
              <div class="txt">
                Lieferung, Kran, Anschluss — und die Einheit steht. Für Park Renewal: Rolling‑Swap
                als „chirurgischer Austausch“ im laufenden Betrieb.
              </div>
              <div class="meta">
                <span class="pill">Minimaler Stillstand</span>
                <span class="pill">Ready for use</span>
              </div>
            </div>
          </div>
        </div>

        <div style="margin-top:16px; display:flex; gap:10px; flex-wrap:wrap">
          <a class="btn primary" href="#kontakt">Projekt anfragen <span class="arrow" aria-hidden="true"></span></a>
          <a class="btn" href="#referenzen">Use‑Cases ansehen <span class="arrow" aria-hidden="true"></span></a>
        </div>
      </div>
    </section>

    <section id="referenzen" class="section">
      <div class="container">
        <div class="section-head">
          <h2>Referenzen & typische Use‑Cases</h2>
          <p class="hint">
            Beispiele, wie die Module als „Business‑Upgrade“ funktionieren — und welche Ziele
            sie typischerweise lösen (ADR‑Uplift, Erweiterung, Saisonverlängerung).
          </p>
        </div>

        <div class="cases">
          <article class="case">
            <div class="thumb" aria-hidden="true"></div>
            <div class="body">
              <h3>Park Renewal · Premium Lodge Upgrade</h3>
              <p>
                Austausch alter Bestandsbauten durch energieeffiziente Holzmodule — im laufenden Betrieb,
                mit Fokus auf ADR‑Uplift und Saisonverlängerung.
              </p>
              <div class="kv" aria-label="Kennzahlen">
                <div class="k"><b>Hebel</b><span>Rolling Swap</span></div>
                <div class="k"><b>Ziel</b><span>Mehrumsatz</span></div>
                <div class="k"><b>Risiko</b><span>Downtime minimiert</span></div>
              </div>
            </div>
          </article>
          <article class="case">
            <div class="thumb" aria-hidden="true"></div>
            <div class="body">
              <h3>Kita · Erweiterungsmodul</h3>
              <p>
                Mehr Raum ohne monatelange Baustelle: Inklusion/U3/Mehrzweck — mit klarer Unterlagen‑Mappe
                und planbarer Montage.
              </p>
              <div class="kv" aria-label="Kennzahlen">
                <div class="k"><b>Hebel</b><span>Tempo & Fixpreis</span></div>
                <div class="k"><b>Ziel</b><span>Plätze schaffen</span></div>
                <div class="k"><b>Fokus</b><span>Raumqualität</span></div>
              </div>
            </div>
          </article>
          <article class="case">
            <div class="thumb" aria-hidden="true"></div>
            <div class="body">
              <h3>Tiny House · Wohnen im Holzmodul</h3>
              <p>
                Schlüsselfertig, modern, warm — klare Pakete, saubere Ausführung, schnelle Realisierung.
              </p>
              <div class="kv" aria-label="Kennzahlen">
                <div class="k"><b>Stil</b><span>Modern & zeitlos</span></div>
                <div class="k"><b>Komfort</b><span>Ganzjahres‑Nutzung</span></div>
                <div class="k"><b>Lieferung</b><span>Planbar</span></div>
              </div>
            </div>
          </article>
          <article class="case">
            <div class="thumb" aria-hidden="true"></div>
            <div class="body">
              <h3>Wellness Box · Experience Upgrade</h3>
              <p>
                Sauna/Kälte/Relax als Upgrade für Glamping, Boutique‑Hosts und private Rückzugsorte —
                ein klarer Differenzierer im Markt.
              </p>
              <div class="kv" aria-label="Kennzahlen">
                <div class="k"><b>Hebel</b><span>Unique stays</span></div>
                <div class="k"><b>Ziel</b><span>Nebensaison</span></div>
                <div class="k"><b>Position</b><span>Premium</span></div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <div class="section-head">
          <h2>FAQ</h2>
          <p class="hint">
            Die häufigsten Fragen — kurz beantwortet. (Details und projektspezifische Klärung im Call.)
          </p>
        </div>

        <div class="faq">
          <details>
            <summary>
              <span class="q">Wie schnell kann ein Modul stehen?</span>
              <span class="plus" aria-hidden="true"></span>
            </summary>
            <div class="a">
              Durch Vorfertigung ist die Montage vor Ort sehr kurz. Die genaue Timeline hängt von
              Standort, Fundament/Anschlüssen und ggf. Genehmigung ab.
            </div>
          </details>
          <details>
            <summary>
              <span class="q">Gibt es standardisierte Varianten oder nur individuell?</span>
              <span class="plus" aria-hidden="true"></span>
            </summary>
            <div class="a">
              Beides: standardisierte Basispakete (schnell & planbar) plus Upgrades (Ausstattung,
              Technik, Wellness, Fassaden).
            </div>
          </details>
          <details>
            <summary>
              <span class="q">Wie funktioniert Park Renewal im laufenden Betrieb?</span>
              <span class="plus" aria-hidden="true"></span>
            </summary>
            <div class="a">
              Rolling Swap: alte Einheit raus, neues Modul rein. Ziel ist minimale Downtime der Parzelle
              und schnelle Wiedervermietbarkeit.
            </div>
          </details>
          <details>
            <summary>
              <span class="q">Unterstützt ihr bei Unterlagen/Genehmigung?</span>
              <span class="plus" aria-hidden="true"></span>
            </summary>
            <div class="a">
              Für B2G/B2B liefern wir eine klare Roadmap (Checklisten, Verantwortlichkeiten) und
              bündeln die projektbezogenen Nachweise — damit Unsicherheit nicht zum Deal‑Killer wird.
            </div>
          </details>
        </div>
      </div>
    </section>

    <section id="kontakt" class="section">
      <div class="container">
        <div class="section-head">
          <h2>Kontakt & nächster Schritt</h2>
          <p class="hint">
            Buche direkt ein Meeting oder schreib uns die Eckdaten (Standort, Use‑Case, Zeitplan).
          </p>
        </div>

        <div class="two-col">
          <div class="stage">
            <div class="stage-inner">
              <h3>Direkt Meeting buchen</h3>
              <p>
                Am schnellsten: 15–30 Minuten. Danach bekommst du ein klares Next‑Step‑Dokument
                (Varianten, Timeline, To‑Dos).
              </p>
              <div class="embed" aria-label="Calendly Embed">
                <iframe
                  title="Calendly — Tectum Ecobau Meeting"
                  src={`${calendlyUrl}?hide_gdpr_banner=1&background_color=05070b&text_color=f5f7fa&primary_color=7cffb2`}
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                ></iframe>
              </div>
            </div>
          </div>

          <div class="stage">
            <div class="stage-inner">
              <h3>Oder per Mail</h3>
              <p>
                Sende uns kurz die wichtigsten Infos — wir melden uns mit Rückfragen und einem
                Vorschlag für das passende Setup.
              </p>
              <div style="margin-top:12px; display:grid; gap:10px">
                <a class="btn primary" href="mailto:info@ecobau-tectum.de?subject=Projektanfrage%20Tectum%20Ecobau&body=Hallo%20Tectum%2C%0D%0A%0D%0AUse-Case%3A%20(Tiny%20House%20%2F%20Park%20Renewal%20%2F%20Kita%20%2F%20Wellness)%0D%0AStandort%3A%20%0D%0AZeitplan%3A%20%0D%0ABudget-Rahmen%3A%20%0D%0AAnmerkungen%3A%20%0D%0A%0D%0AViele%20Gr%C3%BC%C3%9Fe">
                  info@ecobau-tectum.de <span class="arrow" aria-hidden="true"></span>
                </a>
                <a class="btn" href="#prozess">Ablauf ansehen <span class="arrow" aria-hidden="true"></span></a>
                <span class="pill"><b>Tipp</b> · Bilder/Grundstücksplan helfen für die erste Einschätzung.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="grid">
        <div>
          <div><strong style="color:rgba(245,247,250,.86)">Tectum Ecobau</strong></div>
          <div class="small">
            Homepage‑Entwurf im Stil moderner Referenzen (Awwwards‑Look). Nächster Schritt: echte
            Projekte/Referenzen + Produktseiten als Cluster.
          </div>
        </div>
        <div class="small" style="text-align:right">
          <div>Kontakt: <a href="mailto:info@ecobau-tectum.de">info@ecobau-tectum.de</a></div>
          <div>Meeting: <a href={calendlyUrl} target="_blank" rel="noreferrer">Calendly öffnen</a></div>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>
