---
import BaseLayout from "../layouts/BaseLayout.astro";

const calendlyUrl =
  "https://calendly.com/henneberg-webdesign-info/tectum-ecobau-meeting";

const brandNote = "Tiny Häuser & Holzmodule · Vorfertigung · Auslieferung DACH";
---

<BaseLayout
  title="Tectum Ecobau — Wir bauen modern. Und wir bauen mit Holz."
  description="Tectum Ecobau: Tiny Häuser & modulare Holzbau‑Lösungen. Klare Prozesse von Planung bis Montage. Für Wohnen, Hospitality (Park Renewal) und soziale Infrastruktur — inkl. Meeting via Calendly."
>
  <header class="topbar">
    <div class="container topbar-inner">
      <a class="brand" href="#top">
        <span class="mark" aria-hidden="true"></span>
        <div>
          <strong>Tectum Ecobau</strong>
          <div><span>{brandNote}</span></div>
        </div>
      </a>
      <nav class="nav" aria-label="Sektionen">
        <a href="#about">About</a>
        <a href="#collection">Collection</a>
        <a href="#projects">Projects</a>
        <a href="#approach">Approach</a>
        <a class="btn primary" href="#contact">Anfrage <span class="arrow" aria-hidden="true"></span></a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="hero" aria-label="Hero">
      <div class="container">
        <div class="eyebrow">Tectum Ecobau</div>
        <h1>Wir bauen modern — und wir bauen mit Holz.</h1>
        <p class="lead">
          Serielle Vorfertigung, präzise Ausführung, klare Abläufe. Für Tiny Houses, modulare
          Wohnlösungen und Hospitality‑Upgrades mit echter Qualität.
        </p>

        <div style="margin-top:18px; display:flex; gap:10px; flex-wrap:wrap">
          <a class="btn primary" href="#contact">Anfrage starten <span class="arrow" aria-hidden="true"></span></a>
          <a class="btn" href="#projects">Projekte ansehen <span class="arrow" aria-hidden="true"></span></a>
        </div>

        <div class="hero-grid">
          <div class="hero-card">
            <div class="pad">
              <h3>Exceptional timber modules</h3>
              <p>
                Design, Raumklima und Bauqualität, die langfristig funktioniert — mit Planbarkeit in
                Zeit und Budget.
              </p>
            </div>
            <div class="visual" aria-hidden="true">
              <div class="gridlines"></div>
            </div>
          </div>

          <aside class="hero-card">
            <div class="pad">
              <h3>Get a quote</h3>
              <p>
                Kurzer Call oder Mail mit Eckdaten (Use‑Case, Standort, Zeitplan) — wir melden uns mit
                Next Steps.
              </p>
              <div style="margin-top:14px; display:grid; gap:10px">
                <a class="btn primary" href="#contact">Kontakt <span class="arrow" aria-hidden="true"></span></a>
                <a class="btn" href="#approach">Approach <span class="arrow" aria-hidden="true"></span></a>
              </div>
            </div>
          </aside>
        </div>

        <div class="scrollcue" aria-hidden="true">
          <span>Scroll to explore</span>
          <span class="line"></span>
          <span>01</span>
        </div>
      </div>
    </section>

    <section id="about" class="section" aria-label="About">
      <div class="container">
        <div class="section-head">
          <h2>About</h2>
          <p class="hint">
            Wir bringen Architektur in eine wiederholbare, lieferbare Form. Das bedeutet: weniger
            Reibung, mehr Klarheit — und ein Ergebnis, das sich wie Premium anfühlt.
          </p>
        </div>

        <div class="grid">
          <article class="tile">
            <h3>Design</h3>
            <p>Modern, ruhig, materialbewusst — gebaut für echte Nutzung statt Render‑Ästhetik.</p>
            <div style="margin-top:12px"><span class="chip"><b>Fokus</b> Raumgefühl & Details</span></div>
          </article>
          <article class="tile">
            <h3>Quality</h3>
            <p>Präzision in Konstruktion und Ausbau — damit das Ergebnis langfristig überzeugt.</p>
            <div style="margin-top:12px"><span class="chip"><b>Fokus</b> langlebige Ausführung</span></div>
          </article>
          <article class="tile">
            <h3>Process</h3>
            <p>Von Konfiguration bis Montage: klarer Ablauf, saubere Schnittstellen, planbare Lieferung.</p>
            <div style="margin-top:12px"><span class="chip"><b>Fokus</b> planbar & transparent</span></div>
          </article>
        </div>
      </div>
    </section>

    <section id="collection" class="section" aria-label="Collection">
      <div class="container">
        <div class="section-head">
          <h2>Collection</h2>
          <p class="hint">
            Produktwelten, die wir modular denken — mit Varianten, die sich sauber konfigurieren lassen.
          </p>
        </div>

        <div class="collection" role="list">
          <div class="row" role="listitem">
            <div class="name">Tiny House</div>
            <div class="desc">Schlüsselfertig · modern · warm · ganzjährig nutzbar.</div>
            <div class="pill">Living</div>
          </div>
          <div class="row" role="listitem">
            <div class="name">Park Renewal Lodge</div>
            <div class="desc">Upgrade im laufenden Betrieb · Rolling Swap · ADR‑Uplift.</div>
            <div class="pill">Hospitality</div>
          </div>
          <div class="row" role="listitem">
            <div class="name">Kita‑Modul</div>
            <div class="desc">Erweiterung & Naturkita · Unterlagenpaket · planbare Montage.</div>
            <div class="pill">Public</div>
          </div>
          <div class="row" role="listitem">
            <div class="name">Wellness Box</div>
            <div class="desc">Sauna/Relax als Experience‑Upgrade · Nebensaison‑Hebel.</div>
            <div class="pill">Add‑on</div>
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="section" aria-label="Projects">
      <div class="container">
        <div class="section-head">
          <h2>Projects</h2>
          <p class="hint">
            Eine Auswahl typischer Use‑Cases. (Platzhalter‑Visuals — echte Projektbilder können wir als nächstes einpflegen.)
          </p>
        </div>

        <div class="projects">
          <article class="project">
            <div class="thumb" aria-hidden="true"></div>
            <div class="body">
              <h3>Park Renewal Lodge</h3>
              <p>Rolling Swap · Upgrade ohne lange Baustelle · Premium‑Positionierung.</p>
              <div class="meta">
                <span class="chip"><b>Outcome</b> ADR & Auslastung</span>
                <span class="chip"><b>Setup</b> Vorfertigung</span>
              </div>
            </div>
          </article>
          <article class="project">
            <div class="thumb" aria-hidden="true"></div>
            <div class="body">
              <h3>Tiny House Living</h3>
              <p>Schlüsselfertig · modern · ganzjährig — gebaut für Alltag und Wert.</p>
              <div class="meta">
                <span class="chip"><b>Outcome</b> Wohnkomfort</span>
                <span class="chip"><b>Setup</b> Varianten</span>
              </div>
            </div>
          </article>
          <article class="project">
            <div class="thumb" aria-hidden="true"></div>
            <div class="body">
              <h3>Kita‑Erweiterung</h3>
              <p>Mehr Raum mit minimaler Betriebsstörung · Unterlagen & Ablauf klar.</p>
              <div class="meta">
                <span class="chip"><b>Outcome</b> Plätze schaffen</span>
                <span class="chip"><b>Setup</b> Roadmap</span>
              </div>
            </div>
          </article>
          <article class="project">
            <div class="thumb" aria-hidden="true"></div>
            <div class="body">
              <h3>Wellness Box</h3>
              <p>Experience‑Upgrade für Hosts & Private · klare Differenzierung.</p>
              <div class="meta">
                <span class="chip"><b>Outcome</b> Unique stays</span>
                <span class="chip"><b>Setup</b> Add‑on</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="approach" class="section" aria-label="Approach">
      <div class="container">
        <div class="section-head">
          <h2>Approach</h2>
          <p class="hint">
            Ein Ablauf, der die wichtigsten Risiken früh eliminiert und den Rest planbar macht.
          </p>
        </div>

        <div class="grid">
          <article class="tile">
            <h3>01 — Understand</h3>
            <p>Use‑Case, Standort, Zeitplan. Wir klären früh die entscheidenden Constraints.</p>
          </article>
          <article class="tile">
            <h3>02 — Configure</h3>
            <p>Varianten & Pakete. Saubere Schnittstellen zu Fundament, Anschlüssen, Transport.</p>
          </article>
          <article class="tile">
            <h3>03 — Deliver</h3>
            <p>Vorfertigung → Logistik → Montage. Ziel: minimale Downtime, klare Übergabe.</p>
          </article>
        </div>

        <div class="quotes" aria-label="Client stories (Platzhalter)">
          <div class="quote">
            <blockquote>
              „Unvergleichlicher Service, starke Qualität und ein Prozess, der wirklich planbar ist.“
            </blockquote>
            <div class="who">— Kunde · Platzhalter (wird durch echte Referenz ersetzt)</div>
          </div>
          <div class="quote">
            <blockquote>
              „Vom ersten Call bis zur Montage: klar, schnell, professionell.“
            </blockquote>
            <div class="who">— Partner · Platzhalter (wird durch echte Referenz ersetzt)</div>
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="section" aria-label="Contact">
      <div class="container">
        <div class="section-head">
          <h2>Contact</h2>
          <p class="hint">
            Get a quote oder buche direkt ein Meeting.
          </p>
        </div>

        <div class="contact">
          <div class="panel">
            <h3>Get in touch</h3>
            <p>
              Mail mit Eckdaten oder direkt Calendly buchen. Wir antworten mit Next Steps und einem
              passenden Vorschlag (Variante, Timeline, To‑Dos).
            </p>
            <div style="margin-top:14px; display:flex; gap:10px; flex-wrap:wrap">
              <a class="btn primary" href="mailto:info@ecobau-tectum.de?subject=Anfrage%20Tectum%20Ecobau&body=Hallo%20Tectum%2C%0D%0A%0D%0AUse-Case%3A%20%0D%0AStandort%3A%20%0D%0AZeitplan%3A%20%0D%0ABudget%3A%20%0D%0A%0D%0AViele%20Gr%C3%BC%C3%9Fe">
                info@ecobau-tectum.de <span class="arrow" aria-hidden="true"></span>
              </a>
              <a class="btn" href={calendlyUrl} target="_blank" rel="noreferrer">
                Calendly öffnen <span class="arrow" aria-hidden="true"></span>
              </a>
            </div>
            <div style="margin-top:12px; color:var(--muted2); font-size:12.5px">
              Duisburg · Deutschland · DACH Delivery
            </div>
          </div>

          <div class="panel">
            <h3>Book a meeting</h3>
            <p>15–30 Minuten — ideal für Zielbild, Varianten, Timeline.</p>
            <div class="embed" aria-label="Calendly Embed">
              <iframe
                title="Calendly — Tectum Ecobau Meeting"
                src={`${calendlyUrl}?hide_gdpr_banner=1&background_color=0b0c0e&text_color=f6f7f9&primary_color=f6f7f9`}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="grid2">
        <div>
          <div><strong style="color:rgba(246,247,249,.86)">Tectum Ecobau</strong></div>
          <div class="small">Homepage‑Entwurf im Stil von [`fluid.glass`](https://fluid.glass/).</div>
        </div>
        <div class="small" style="text-align:right">
          <div><a href="#about">About</a> · <a href="#collection">Collection</a> · <a href="#projects">Projects</a></div>
          <div><a href="#approach">Approach</a> · <a href="#contact">Contact</a></div>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>
